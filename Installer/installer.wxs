<?xml version="1.0" encoding="UTF-8"?>
<!--
  WiX v4 installer for NCCA Meeting Notes.
  Build via GitHub Actions — see .github/workflows/dotnet.yml.
  Manual build:
    dotnet tool install --global wix
    dotnet publish MeetingNotes.csproj -r win-x64 -c Release -o publish\ --self-contained false
    wix build Installer\installer.wxs -d PublishDir=publish -d Version=1.26.518 -o nccameetingnotes.msi
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">

  <Package Name="NCCA Meeting Notes"
           Language="1033"
           Version="$(var.Version)"
           Manufacturer="Shane Newsom"
           UpgradeCode="A3F7B2C8-4D5E-4F7A-8B9C-0D1E2F3A4B5C">

    <MajorUpgrade DowngradeErrorMessage="A newer version of NCCA Meeting Notes is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <Feature Id="Main" Level="1">
      <ComponentGroupRef Id="AppFiles" />
      <ComponentRef Id="StartMenuShortcut" />
    </Feature>

    <StandardDirectory Id="ProgramFiles6432Folder">
      <Directory Id="INSTALLFOLDER" Name="NCCA Meeting Notes" />
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ShortcutFolder" Name="NCCA Meeting Notes" />
    </StandardDirectory>

    <Component Id="StartMenuShortcut" Directory="ShortcutFolder" Guid="*">
      <Shortcut Id="AppShortcut"
                Name="NCCA Meeting Notes"
                Target="[INSTALLFOLDER]MeetingNotes.exe"
                WorkingDirectory="INSTALLFOLDER" />
      <RemoveFolder Id="RemoveShortcutFolder" Directory="ShortcutFolder" On="uninstall" />
      <RegistryValue Root="HKCU"
                     Key="Software\NccaMeetingNotes"
                     Name="installed"
                     Type="integer"
                     Value="1"
                     KeyPath="yes" />
    </Component>

  </Package>

  <Fragment>
    <ComponentGroup Id="AppFiles" Directory="INSTALLFOLDER">
      <Files Include="$(var.PublishDir)\**\*" />
    </ComponentGroup>
  </Fragment>

</Wix>
