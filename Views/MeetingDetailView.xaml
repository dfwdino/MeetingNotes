<Page x:Class="MeetingNotes.Views.MeetingDetailView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.modernwpf.com/2019"
      Background="{DynamicResource AppBackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" BorderThickness="0,0,0,1" BorderBrush="#FF2D2D2D" Padding="24,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="TitleBox"
                         Background="Transparent" BorderThickness="0"
                         Foreground="White" FontSize="20" FontWeight="SemiBold"
                         FontFamily="Segoe UI" CaretBrush="{StaticResource AccentBrush}"
                         VerticalAlignment="Center"
                         TextChanged="TitleBox_TextChanged">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="TextBox">
                                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                                BorderBrush="Transparent" BorderThickness="0"
                                                CornerRadius="4" Padding="4,2">
                                            <ScrollViewer x:Name="PART_ContentHost"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsFocused" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#FF2A2A2A"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </TextBox.Style>
                </TextBox>
                <TextBlock Grid.Column="1" x:Name="MetaText"
                           Foreground="#FF666666" FontSize="12"
                           VerticalAlignment="Center" Margin="16,0"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button x:Name="ReprocessButton"
                            Content="↺  Re-process"
                            Style="{DynamicResource GhostButton}"
                            ToolTip="Re-run transcription and summary for this meeting"
                            Margin="0,0,8,0" Visibility="Collapsed"
                            Click="ReprocessButton_Click"/>
                    <Button x:Name="ExportButton"
                            Content="⬇  Export"
                            Style="{DynamicResource GhostButton}"
                            ToolTip="Export meeting notes, transcript and summary to a text file"
                            Margin="0,0,8,0" Visibility="Collapsed"
                            Click="ExportButton_Click"/>
                    <Button x:Name="RecordButton"
                            Content="● Record New"
                            Style="{DynamicResource DangerButton}"
                            Click="RecordButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Tab Bar -->
        <Border Grid.Row="1" BorderThickness="0,0,0,1" BorderBrush="#FF2D2D2D">
            <StackPanel Orientation="Horizontal" Margin="16,0">
                <Button x:Name="TabMyNotes" Content="My Notes"
                        Click="Tab_Click" Tag="MyNotes">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource GhostButton}">
                            <Setter Property="Padding" Value="16,12"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="BorderThickness" Value="0,0,0,2"/>
                            <Setter Property="BorderBrush" Value="Transparent"/>
                        </Style>
                    </Button.Style>
                </Button>
                <Button x:Name="TabTranscript" Content="Transcript"
                        Click="Tab_Click" Tag="Transcript">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource GhostButton}">
                            <Setter Property="Padding" Value="16,12"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="BorderThickness" Value="0,0,0,2"/>
                            <Setter Property="BorderBrush" Value="Transparent"/>
                        </Style>
                    </Button.Style>
                </Button>
                <Button x:Name="TabSummary" Content="AI Summary"
                        Click="Tab_Click" Tag="Summary">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource GhostButton}">
                            <Setter Property="Padding" Value="16,12"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="BorderThickness" Value="0,0,0,2"/>
                            <Setter Property="BorderBrush" Value="Transparent"/>
                        </Style>
                    </Button.Style>
                </Button>
                <Button x:Name="TabChat" Content="Ask Questions"
                        Click="Tab_Click" Tag="Chat">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource GhostButton}">
                            <Setter Property="Padding" Value="16,12"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="BorderThickness" Value="0,0,0,2"/>
                            <Setter Property="BorderBrush" Value="Transparent"/>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Border>

        <!-- Tab Content -->
        <Grid Grid.Row="2">

            <!-- My Notes Tab -->
            <Grid x:Name="MyNotesPanel" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Formatting toolbar -->
                <Border Grid.Row="0" BorderThickness="0,0,0,1" BorderBrush="#FF2D2D2D" Padding="14,5">
                    <StackPanel Orientation="Horizontal">
                        <Button Style="{DynamicResource FormatButton}" ToolTip="Bold (Ctrl+B)"
                                Click="FormatBold_Click">
                            <TextBlock Text="B" FontWeight="Bold" FontSize="13"/>
                        </Button>
                        <Button Style="{DynamicResource FormatButton}" ToolTip="Italic (Ctrl+I)"
                                Margin="2,0,0,0" Click="FormatItalic_Click">
                            <TextBlock Text="I" FontStyle="Italic" FontSize="13"/>
                        </Button>
                        <Button Style="{DynamicResource FormatButton}" ToolTip="Underline (Ctrl+U)"
                                Margin="2,0,0,0" Click="FormatUnderline_Click">
                            <TextBlock FontSize="13">
                                <Underline>U</Underline>
                            </TextBlock>
                        </Button>
                        <Separator Width="1" Height="16" Background="#FF3A3A3A" Margin="6,0"/>
                        <Button Style="{DynamicResource FormatButton}" ToolTip="Bullet list"
                                Click="FormatBullets_Click">
                            <TextBlock Text="•≡" FontSize="12"/>
                        </Button>
                        <Button Style="{DynamicResource FormatButton}" ToolTip="Numbered list"
                                Margin="2,0,0,0" Click="FormatNumbered_Click">
                            <TextBlock Text="1≡" FontSize="12"/>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- Editable notes area -->
                <RichTextBox Grid.Row="1" x:Name="MyNotesBox"
                             Style="{DynamicResource DarkRichTextBox}"
                             AcceptsReturn="True"
                             AcceptsTab="True"
                             TextChanged="MyNotes_TextChanged"/>
            </Grid>

            <!-- Transcript Tab -->
            <ScrollViewer x:Name="TranscriptPanel" Visibility="Collapsed"
                          VerticalScrollBarVisibility="Auto" Padding="24,16">
                <TextBox x:Name="TranscriptText" Style="{StaticResource ReadOnlyContent}"/>
            </ScrollViewer>

            <!-- AI Summary Tab -->
            <ScrollViewer x:Name="SummaryPanel" Visibility="Collapsed"
                          VerticalScrollBarVisibility="Auto" Padding="24,16">
                <TextBox x:Name="SummaryText" Style="{StaticResource ReadOnlyContent}"/>
            </ScrollViewer>

            <!-- Chat Tab -->
            <Grid x:Name="ChatPanel" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <ScrollViewer Grid.Row="0" x:Name="ChatScrollViewer"
                              VerticalScrollBarVisibility="Auto" Padding="24,16">
                    <StackPanel x:Name="ChatMessages"/>
                </ScrollViewer>

                <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="#FF2D2D2D"
                        Padding="16,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="ChatInputBox"
                                 Style="{DynamicResource DarkTextBox}"
                                 AcceptsReturn="False"
                                 ui:ControlHelper.PlaceholderText="Ask something about this meeting..."
                                 KeyDown="ChatInputBox_KeyDown"/>
                        <Button Grid.Column="1" Content="Send"
                                Style="{DynamicResource PrimaryButton}"
                                Margin="8,0,0,0" Click="SendChatButton_Click"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- Empty/New Meeting State -->
            <StackPanel x:Name="NewMeetingPanel"
                        VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Ready to record" Foreground="#FF555555"
                           FontSize="16" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                <TextBlock Text="Click 'Record New' to start capturing this meeting"
                           Foreground="#FF444444" FontSize="13" HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
