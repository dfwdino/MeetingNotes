<Page x:Class="MeetingNotes.Views.SettingsView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.modernwpf.com/2019"
      Background="#FF202020">
    <Page.Resources>
        <ResourceDictionary Source="/Themes/DarkTheme.xaml"/>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" BorderThickness="0,0,0,1" BorderBrush="#FF2D2D2D" Padding="24,16">
            <TextBlock Text="Settings" Foreground="White" FontSize="20" FontWeight="SemiBold"/>
        </Border>

        <!-- Settings Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24,20,24,20" MaxWidth="640">

                <!-- ── WHISPER ─────────────────────────────────── -->
                <TextBlock Text="WHISPER  (Transcription)" Foreground="#FF0078D4"
                           FontSize="11" FontWeight="Bold" Margin="0,0,0,12"/>

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Margin="0,0,8,0">
                        <TextBlock Text="Model" Foreground="#FF888888" FontSize="12" Margin="0,0,0,6"/>
                        <ComboBox x:Name="WhisperModelBox"
                                  Background="#FF1A1A1A" Foreground="#FFE0E0E0"
                                  BorderBrush="#FF3A3A3A" FontSize="13"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="8,0,0,0">
                        <TextBlock Text="Live Transcription Chunk" Foreground="#FF888888"
                                   FontSize="12" Margin="0,0,0,6"/>
                        <ComboBox x:Name="ChunkIntervalBox"
                                  Background="#FF1A1A1A" Foreground="#FFE0E0E0"
                                  BorderBrush="#FF3A3A3A" FontSize="13"/>
                    </StackPanel>
                </Grid>

                <StackPanel Margin="0,0,0,24">
                    <TextBlock Text="Model cache folder" Foreground="#FF888888"
                               FontSize="12" Margin="0,0,0,6"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="WhisperFolderBox" Style="{StaticResource DarkTextBox}"/>
                        <Button Grid.Column="1" Content="Browse" Style="{StaticResource GhostButton}"
                                Margin="8,0,0,0" Click="BrowseWhisperFolder_Click"/>
                    </Grid>
                </StackPanel>

                <Rectangle Height="1" Fill="#FF2D2D2D" Margin="0,0,0,20"/>

                <!-- ── OLLAMA ──────────────────────────────────── -->
                <TextBlock Text="OLLAMA  (Summarization &amp; Chat)" Foreground="#FF0078D4"
                           FontSize="11" FontWeight="Bold" Margin="0,0,0,12"/>

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Server URL" Foreground="#FF888888" FontSize="12" Margin="0,0,0,6"/>
                        <TextBox x:Name="OllamaUrlBox" Style="{StaticResource DarkTextBox}"/>
                    </StackPanel>
                    <Button Grid.Column="1" Content="Test Connection"
                            Style="{StaticResource GhostButton}"
                            Margin="8,18,0,0" Click="TestOllama_Click"/>
                </Grid>

                <TextBlock x:Name="OllamaStatusText" Foreground="#FF888888"
                           FontSize="12" Margin="0,0,0,12"/>

                <StackPanel Margin="0,0,0,12">
                    <TextBlock Text="Model" Foreground="#FF888888" FontSize="12" Margin="0,0,0,6"/>
                    <ComboBox x:Name="OllamaModelBox"
                              Background="#FF1A1A1A" Foreground="#FFE0E0E0"
                              BorderBrush="#FF3A3A3A" FontSize="13"/>
                </StackPanel>

                <StackPanel Margin="0,0,0,24">
                    <TextBlock Text="Summary prompt template" Foreground="#FF888888"
                               FontSize="12" Margin="0,0,0,6"/>
                    <TextBox x:Name="SummaryPromptBox"
                             Style="{StaticResource DarkTextBox}"
                             AcceptsReturn="True" TextWrapping="Wrap"
                             Height="100" VerticalScrollBarVisibility="Auto"/>
                </StackPanel>

                <Rectangle Height="1" Fill="#FF2D2D2D" Margin="0,0,0,20"/>

                <!-- ── RECORDING ──────────────────────────────── -->
                <TextBlock Text="RECORDING" Foreground="#FF0078D4"
                           FontSize="11" FontWeight="Bold" Margin="0,0,0,12"/>

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Margin="0,0,8,0">
                        <TextBlock Text="Audio format" Foreground="#FF888888" FontSize="12" Margin="0,0,0,6"/>
                        <ComboBox x:Name="AudioFormatBox"
                                  Background="#FF1A1A1A" Foreground="#FFE0E0E0"
                                  BorderBrush="#FF3A3A3A" FontSize="13"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="8,0,0,0">
                        <TextBlock Text="MP3 bitrate" Foreground="#FF888888" FontSize="12" Margin="0,0,0,6"/>
                        <ComboBox x:Name="Mp3BitrateBox"
                                  Background="#FF1A1A1A" Foreground="#FFE0E0E0"
                                  BorderBrush="#FF3A3A3A" FontSize="13"/>
                    </StackPanel>
                </Grid>

                <CheckBox x:Name="DeleteAudioBox" Margin="0,0,0,24"
                          Foreground="#FFCCCCCC" FontSize="13">
                    Delete audio file after transcription (saves disk space)
                </CheckBox>

                <Rectangle Height="1" Fill="#FF2D2D2D" Margin="0,0,0,20"/>

                <!-- ── STORAGE ─────────────────────────────────── -->
                <TextBlock Text="STORAGE" Foreground="#FF0078D4"
                           FontSize="11" FontWeight="Bold" Margin="0,0,0,12"/>

                <StackPanel Margin="0,0,0,12">
                    <TextBlock Text="Recordings folder" Foreground="#FF888888" FontSize="12" Margin="0,0,0,6"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="RecordingsFolderBox" Style="{StaticResource DarkTextBox}"/>
                        <Button Grid.Column="1" Content="Browse" Style="{StaticResource GhostButton}"
                                Margin="8,0,0,0" Click="BrowseRecordingsFolder_Click"/>
                    </Grid>
                </StackPanel>

                <Rectangle Height="1" Fill="#FF2D2D2D" Margin="0,0,0,20"/>

                <!-- ── GENERAL ─────────────────────────────────── -->
                <TextBlock Text="GENERAL" Foreground="#FF0078D4"
                           FontSize="11" FontWeight="Bold" Margin="0,0,0,12"/>

                <StackPanel Margin="0,0,0,12">
                    <TextBlock Text="Theme" Foreground="#FF888888" FontSize="12" Margin="0,0,0,6"/>
                    <ComboBox x:Name="ThemeBox" Width="180" HorizontalAlignment="Left"
                              Background="#FF1A1A1A" Foreground="#FFE0E0E0"
                              BorderBrush="#FF3A3A3A" FontSize="13"/>
                </StackPanel>

                <CheckBox x:Name="StartupBox" Margin="0,0,0,10"
                          Foreground="#FFCCCCCC" FontSize="13">
                    Launch at Windows startup
                </CheckBox>
                <CheckBox x:Name="MinimizeTrayBox" Margin="0,0,0,10"
                          Foreground="#FFCCCCCC" FontSize="13">
                    Minimize to tray when closed
                </CheckBox>
                <CheckBox x:Name="TrayTimerBox" Margin="0,0,0,24"
                          Foreground="#FFCCCCCC" FontSize="13">
                    Show recording timer in tray icon
                </CheckBox>

                <Rectangle Height="1" Fill="#FF2D2D2D" Margin="0,0,0,20"/>

                <!-- ── APP WATCHER ────────────────────────────── -->
                <TextBlock Text="APP WATCHER" Foreground="#FF0078D4"
                           FontSize="11" FontWeight="Bold" Margin="0,0,0,12"/>

                <CheckBox x:Name="AppWatcherEnabledBox" Margin="0,0,0,14"
                          Foreground="#FFCCCCCC" FontSize="13">
                    Prompt to record when a watched app becomes active
                </CheckBox>

                <StackPanel Margin="0,0,0,4">
                    <TextBlock Text="Apps to watch  (one per line — partial process name is fine)"
                               Foreground="#FF888888" FontSize="12" Margin="0,0,0,5"/>
                    <TextBlock Foreground="#FF555555" FontSize="11" Margin="0,0,0,8">
                        <Run Text="Common: "/>
                        <Run Text="zoom, ms-teams, discord, slack, webex" FontStyle="Italic"/>
                    </TextBlock>
                    <TextBox x:Name="WatchedAppsBox"
                             Style="{StaticResource DarkTextBox}"
                             AcceptsReturn="True" TextWrapping="Wrap"
                             Height="90" VerticalScrollBarVisibility="Auto"/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <!-- Save Bar -->
        <Border Grid.Row="2" BorderThickness="0,1,0,0" BorderBrush="#FF2D2D2D" Padding="24,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock x:Name="SaveStatusText" Foreground="#FF4CAF50" FontSize="12"
                           VerticalAlignment="Center" Margin="0,0,16,0" Visibility="Collapsed"/>
                <Button Content="Cancel" Style="{StaticResource GhostButton}"
                        Margin="0,0,8,0" Click="CancelButton_Click"/>
                <Button Content="Save Settings" Style="{StaticResource PrimaryButton}"
                        Click="SaveButton_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
