<Page x:Class="MeetingNotes.Views.SettingsView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.modernwpf.com/2019"
      Background="{DynamicResource AppBackgroundBrush}"
      Loaded="Page_Loaded">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" BorderThickness="0,0,0,1" BorderBrush="{DynamicResource SeparatorBrush}" Padding="24,16">
            <TextBlock Text="Settings" Foreground="{DynamicResource HeaderTextBrush}" FontSize="20" FontWeight="SemiBold"/>
        </Border>

        <!-- Settings Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24,20,24,20" MaxWidth="640">

                <!-- ── WHISPER ─────────────────────────────────── -->
                <TextBlock Text="WHISPER  (Transcription)" Foreground="#FF0078D4"
                           FontSize="11" FontWeight="Bold" Margin="0,0,0,12"/>

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Margin="0,0,8,0">
                        <TextBlock Text="Model" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,6"/>
                        <ComboBox x:Name="WhisperModelBox"
                                  Background="{DynamicResource InputBackgroundBrush}" Foreground="{DynamicResource TextPrimaryBrush}"
                                  BorderBrush="#FF3A3A3A" FontSize="13"/>
                    </StackPanel>
                    <!-- Live Transcription Chunk — hidden until feature is wired up -->
                    <StackPanel Grid.Column="1" Margin="8,0,0,0" Visibility="Collapsed">
                        <TextBlock Text="Live Transcription Chunk" Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="12" Margin="0,0,0,6"/>
                        <ComboBox x:Name="ChunkIntervalBox"
                                  Background="{DynamicResource InputBackgroundBrush}" Foreground="{DynamicResource TextPrimaryBrush}"
                                  BorderBrush="#FF3A3A3A" FontSize="13"/>
                    </StackPanel>
                </Grid>

                <StackPanel Margin="0,0,0,24">
                    <TextBlock Text="Model cache folder" Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="12" Margin="0,0,0,6"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="WhisperFolderBox" Style="{DynamicResource DarkTextBox}"/>
                        <Button Grid.Column="1" Content="Browse" Style="{DynamicResource GhostButton}"
                                Margin="8,0,0,0" Click="BrowseWhisperFolder_Click"/>
                    </Grid>
                </StackPanel>

                <Rectangle Height="1" Fill="{DynamicResource SeparatorBrush}" Margin="0,0,0,20"/>

                <!-- ── OLLAMA ──────────────────────────────────── -->
                <TextBlock Text="OLLAMA  (Summarization &amp; Chat)" Foreground="#FF0078D4"
                           FontSize="11" FontWeight="Bold" Margin="0,0,0,12"/>

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Server URL" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,6"/>
                        <TextBox x:Name="OllamaUrlBox" Style="{DynamicResource DarkTextBox}"/>
                    </StackPanel>
                    <Button Grid.Column="1" Content="Test Connection"
                            Style="{DynamicResource GhostButton}"
                            Margin="8,18,0,0" Click="TestOllama_Click"/>
                </Grid>

                <TextBlock x:Name="OllamaStatusText" Foreground="{DynamicResource TextSecondaryBrush}"
                           FontSize="12" Margin="0,0,0,12"/>

                <!-- Default model display + validation -->
                <Border Margin="0,0,0,6" Padding="10,8" CornerRadius="4" Background="{DynamicResource InputBackgroundBrush}"
                        BorderBrush="#FF3A3A3A" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Default Model:" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock x:Name="DefaultModelLabel" Grid.Column="1"
                                   FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock x:Name="DefaultModelStatus" Grid.Column="2"
                                   FontSize="12" VerticalAlignment="Center" Margin="12,0,0,0"/>
                    </Grid>
                </Border>

                <!-- Warning when default not installed -->
                <Border x:Name="DefaultModelWarning" CornerRadius="4" Padding="10,7"
                        Margin="0,0,0,8" Visibility="Collapsed"
                        Background="#FF3D2000" BorderBrush="#FF8B4500" BorderThickness="1">
                    <TextBlock Foreground="#FFFFA726" FontSize="12" TextWrapping="Wrap">
                        ⚠  This default model is not installed in Ollama.
                        Select an installed model below and click Set as Default.
                    </TextBlock>
                </Border>

                <!-- Installed models list + Set as Default button -->
                <StackPanel x:Name="InstalledModelsPanel" Margin="0,0,0,12">
                    <TextBlock Text="Installed Models" Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="12" Margin="0,0,0,6"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox x:Name="OllamaModelBox"
                                  Background="{DynamicResource InputBackgroundBrush}" Foreground="{DynamicResource TextPrimaryBrush}"
                                  BorderBrush="#FF3A3A3A" FontSize="13"/>
                        <Button x:Name="SetDefaultModelButton" Grid.Column="1"
                                Content="Set as Default" Style="{DynamicResource GhostButton}"
                                Margin="8,0,0,0" Click="SetDefaultModel_Click"/>
                    </Grid>
                </StackPanel>

                <!-- Manual entry — shown when server can't be reached -->
                <StackPanel x:Name="ManualModelPanel" Margin="0,0,0,12" Visibility="Collapsed">
                    <TextBlock Text="Server unreachable — enter model name manually"
                               Foreground="#FFFFA726" FontSize="12" Margin="0,0,0,6"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="ManualModelBox"
                                 Style="{DynamicResource DarkTextBox}"
                                 ui:ControlHelper.PlaceholderText="e.g. llama3.2:3b"/>
                        <Button Grid.Column="1" Content="Set as Default"
                                Style="{DynamicResource GhostButton}"
                                Margin="8,0,0,0" Click="SetDefaultModelManual_Click"/>
                    </Grid>
                </StackPanel>

                <StackPanel Margin="0,0,0,24">
                    <TextBlock Text="Summary prompt template" Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="12" Margin="0,0,0,6"/>
                    <TextBox x:Name="SummaryPromptBox"
                             Style="{DynamicResource DarkTextBox}"
                             AcceptsReturn="True" TextWrapping="Wrap"
                             Height="100" VerticalScrollBarVisibility="Auto"/>
                </StackPanel>

                <Rectangle Height="1" Fill="{DynamicResource SeparatorBrush}" Margin="0,0,0,20"/>

                <!-- ── RECORDING ──────────────────────────────── -->
                <TextBlock Text="RECORDING" Foreground="#FF0078D4"
                           FontSize="11" FontWeight="Bold" Margin="0,0,0,12"/>

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Margin="0,0,8,0">
                        <TextBlock Text="Audio format" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,6"/>
                        <ComboBox x:Name="AudioFormatBox"
                                  Background="{DynamicResource InputBackgroundBrush}" Foreground="{DynamicResource TextPrimaryBrush}"
                                  BorderBrush="#FF3A3A3A" FontSize="13"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="8,0,0,0">
                        <TextBlock Text="MP3 bitrate" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,6"/>
                        <ComboBox x:Name="Mp3BitrateBox"
                                  Background="{DynamicResource InputBackgroundBrush}" Foreground="{DynamicResource TextPrimaryBrush}"
                                  BorderBrush="#FF3A3A3A" FontSize="13"/>
                    </StackPanel>
                </Grid>

                <CheckBox x:Name="DeleteAudioBox" Margin="0,0,0,24"
                          Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13">
                    Delete audio file after transcription (saves disk space)
                </CheckBox>

                <Rectangle Height="1" Fill="{DynamicResource SeparatorBrush}" Margin="0,0,0,20"/>

                <!-- ── STORAGE ─────────────────────────────────── -->
                <TextBlock Text="STORAGE" Foreground="#FF0078D4"
                           FontSize="11" FontWeight="Bold" Margin="0,0,0,12"/>

                <StackPanel Margin="0,0,0,12">
                    <TextBlock Text="Recordings folder" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,6"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="RecordingsFolderBox" Style="{DynamicResource DarkTextBox}"/>
                        <Button Grid.Column="1" Content="Browse" Style="{DynamicResource GhostButton}"
                                Margin="8,0,0,0" Click="BrowseRecordingsFolder_Click"/>
                    </Grid>
                </StackPanel>

                <Rectangle Height="1" Fill="{DynamicResource SeparatorBrush}" Margin="0,0,0,20"/>

                <!-- ── GENERAL ─────────────────────────────────── -->
                <TextBlock Text="GENERAL" Foreground="#FF0078D4"
                           FontSize="11" FontWeight="Bold" Margin="0,0,0,12"/>

                <StackPanel Margin="0,0,0,12">
                    <TextBlock Text="Theme" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,6"/>
                    <ComboBox x:Name="ThemeBox" Width="180" HorizontalAlignment="Left"
                              Background="{DynamicResource InputBackgroundBrush}" Foreground="{DynamicResource TextPrimaryBrush}"
                              BorderBrush="#FF3A3A3A" FontSize="13"/>
                </StackPanel>

                <CheckBox x:Name="StartupBox" Margin="0,0,0,10"
                          Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13">
                    Launch at Windows startup
                </CheckBox>
                <CheckBox x:Name="MinimizeTrayBox" Margin="0,0,0,10"
                          Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13">
                    Minimize to tray when closed
                </CheckBox>
                <CheckBox x:Name="TrayTimerBox" Margin="0,0,0,24"
                          Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13">
                    Show recording timer in tray icon
                </CheckBox>

                <Rectangle Height="1" Fill="{DynamicResource SeparatorBrush}" Margin="0,0,0,20"/>

                <!-- ── APP WATCHER ────────────────────────────── -->
                <TextBlock Text="APP WATCHER" Foreground="#FF0078D4"
                           FontSize="11" FontWeight="Bold" Margin="0,0,0,12"/>

                <CheckBox x:Name="AppWatcherEnabledBox" Margin="0,0,0,14"
                          Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13">
                    Prompt to record when a watched app becomes active
                </CheckBox>

                <StackPanel Margin="0,0,0,4">
                    <TextBlock Text="Apps to watch  (one per line — partial process name is fine)"
                               Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,5"/>
                    <TextBlock Foreground="{DynamicResource TextMutedBrush}" FontSize="11" Margin="0,0,0,8">
                        <Run Text="Common: "/>
                        <Run Text="zoom, ms-teams, discord, slack, webex" FontStyle="Italic"/>
                    </TextBlock>
                    <TextBox x:Name="WatchedAppsBox"
                             Style="{DynamicResource DarkTextBox}"
                             AcceptsReturn="True" TextWrapping="Wrap"
                             Height="90" VerticalScrollBarVisibility="Auto"/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <!-- Save Bar -->
        <Border Grid.Row="2" BorderThickness="0,1,0,0" BorderBrush="{DynamicResource SeparatorBrush}" Padding="24,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock x:Name="SaveStatusText" Foreground="#FF4CAF50" FontSize="12"
                           VerticalAlignment="Center" Margin="0,0,16,0" Visibility="Collapsed"/>
                <Button Content="Cancel" Style="{DynamicResource GhostButton}"
                        Margin="0,0,8,0" Click="CancelButton_Click"/>
                <Button Content="Save Settings" Style="{DynamicResource PrimaryButton}"
                        Click="SaveButton_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
