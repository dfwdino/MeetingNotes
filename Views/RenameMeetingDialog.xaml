<Window x:Class="MeetingNotes.Views.RenameMeetingDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="Rename Meeting" Height="160" Width="420"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource PanelBackgroundBrush}">
    <StackPanel Margin="20">
        <TextBlock Text="Meeting name" Foreground="#FF888888" FontSize="12" Margin="0,0,0,8"/>
        <TextBox x:Name="TitleBox" Style="{DynamicResource DarkTextBox}"
                 Margin="0,0,0,16"
                 KeyDown="TitleBox_KeyDown"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Style="{DynamicResource GhostButton}"
                    Margin="0,0,8,0" Click="CancelButton_Click"/>
            <Button Content="Rename" Style="{DynamicResource PrimaryButton}"
                    Click="RenameButton_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
