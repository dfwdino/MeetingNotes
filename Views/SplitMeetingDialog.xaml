<Window x:Class="MeetingNotes.Views.SplitMeetingDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="Split Meeting" Height="560" Width="620"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource PanelBackgroundBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Split Meeting" FontSize="16" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,6"/>
        <TextBlock Grid.Row="1"
                   Text="Click the first line that belongs to the new meeting. Everything from that line onward moves to the new meeting."
                   Foreground="#FF888888" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,12"/>

        <Border Grid.Row="2" BorderBrush="#FF3A3A3A" BorderThickness="1" CornerRadius="4" Margin="0,0,0,8">
            <ListBox x:Name="LinesList"
                     Background="{DynamicResource InputBackgroundBrush}"
                     Foreground="{DynamicResource TextPrimaryBrush}"
                     FontFamily="Consolas" FontSize="12"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     SelectionChanged="LinesList_SelectionChanged"
                     BorderThickness="0"/>
        </Border>

        <TextBlock Grid.Row="3" x:Name="SelectionInfo" Text="Select a line above to set the split point"
                   Foreground="#FF888888" FontSize="11" Margin="0,0,0,12"/>

        <Grid Grid.Row="4" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="New meeting title:" Foreground="#FF888888" FontSize="12"
                       VerticalAlignment="Center" Margin="0,0,10,0"/>
            <TextBox Grid.Column="1" x:Name="TitleBox" Style="{DynamicResource DarkTextBox}"
                     KeyDown="TitleBox_KeyDown"/>
        </Grid>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Style="{DynamicResource GhostButton}"
                    Margin="0,0,8,0" Click="CancelButton_Click"/>
            <Button x:Name="SplitButton" Content="✂  Split" Style="{DynamicResource PrimaryButton}"
                    IsEnabled="False" Click="SplitButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
