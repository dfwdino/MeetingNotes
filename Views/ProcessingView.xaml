<Page x:Class="MeetingNotes.Views.ProcessingView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#FF202020">
    <Page.Resources>
        <ResourceDictionary Source="/Themes/DarkTheme.xaml"/>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Compact header + steps -->
        <StackPanel Grid.Row="0" Margin="32,20,32,12">

            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                <TextBlock Text="🎙️" FontSize="22" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock Text="Processing your meeting" Foreground="White"
                           FontSize="17" FontWeight="SemiBold" VerticalAlignment="Center"/>
            </StackPanel>
            <TextBlock x:Name="StatusText" Text="Preparing..."
                       Foreground="#FF888888" FontSize="12" Margin="0,0,0,12"/>

            <!-- Steps side by side -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Step 1 -->
                <Border Grid.Column="0" Background="#FF252525" CornerRadius="6" Padding="12,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Width="26" Height="26" CornerRadius="13" Background="#FF2A2A2A"
                                Margin="0,0,10,0" VerticalAlignment="Center">
                            <TextBlock x:Name="Step1Icon" Text="1" Foreground="#FF888888"
                                       FontSize="12" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Transcribing" Foreground="White"
                                       FontSize="12" FontWeight="Medium"/>
                            <TextBlock x:Name="TranscribeStatusText" Text="Waiting"
                                       Foreground="#FF666666" FontSize="11" Margin="0,1,0,0"/>
                        </StackPanel>
                        <TextBlock x:Name="Step1Check" Grid.Column="2" Text="✓"
                                   Foreground="#FF4CAF50" FontSize="15" VerticalAlignment="Center"
                                   Visibility="Collapsed"/>
                    </Grid>
                </Border>

                <!-- Step 2 -->
                <Border Grid.Column="2" Background="#FF252525" CornerRadius="6" Padding="12,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Width="26" Height="26" CornerRadius="13" Background="#FF2A2A2A"
                                Margin="0,0,10,0" VerticalAlignment="Center">
                            <TextBlock x:Name="Step2Icon" Text="2" Foreground="#FF888888"
                                       FontSize="12" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Summarizing" Foreground="White"
                                       FontSize="12" FontWeight="Medium"/>
                            <TextBlock x:Name="SummarizeStatusText" Text="Waiting"
                                       Foreground="#FF666666" FontSize="11" Margin="0,1,0,0"/>
                        </StackPanel>
                        <TextBlock x:Name="Step2Check" Grid.Column="2" Text="✓"
                                   Foreground="#FF4CAF50" FontSize="15" VerticalAlignment="Center"
                                   Visibility="Collapsed"/>
                    </Grid>
                </Border>
            </Grid>
        </StackPanel>

        <!-- Live transcript — takes all remaining space -->
        <Grid Grid.Row="1" Margin="32,0,32,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Text="LIVE TRANSCRIPT PREVIEW" Foreground="#FF888888"
                       FontSize="10" FontWeight="SemiBold" Margin="0,0,0,6"/>
            <Border Grid.Row="1" Background="#FF1A1A1A" CornerRadius="6" Padding="14,10">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="LivePreviewText" Foreground="#FFCCCCCC"
                               FontSize="13" TextWrapping="Wrap" LineHeight="22"/>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Error / Retry panel -->
        <Border x:Name="ErrorPanel" Grid.Row="2" Visibility="Collapsed"
                Background="#FF2A1A1A" CornerRadius="8"
                BorderBrush="#FF8B0000" BorderThickness="1"
                Padding="16,12" Margin="32,8,32,16">
            <StackPanel>
                <TextBlock x:Name="ErrorText" Foreground="#FFFF6B6B"
                           FontSize="12" TextWrapping="Wrap" Margin="0,0,0,10"/>
                <Button x:Name="RetryButton" Content="↺  Retry Processing"
                        Style="{StaticResource PrimaryButton}"
                        Click="RetryButton_Click" HorizontalAlignment="Left"/>
            </StackPanel>
        </Border>

    </Grid>
</Page>
