<Window x:Class="MeetingNotes.Views.AboutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="About Meeting Notes"
        Height="340" Width="420"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource SidebarBackgroundBrush}"
        Icon="/MeetingNotes.ico">

    <StackPanel Margin="36,32,36,28">

        <!-- Icon + App name -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,6">
            <Image Source="/MeetingNotes.ico" Width="42" Height="42"
                   VerticalAlignment="Center" Margin="0,0,12,0"
                   RenderOptions.BitmapScalingMode="HighQuality"/>
            <TextBlock Text="Meeting Notes" Foreground="White"
                       FontSize="26" FontWeight="SemiBold" FontFamily="Segoe UI"
                       VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Version -->
        <TextBlock x:Name="VersionText" HorizontalAlignment="Center"
                   Foreground="#FF888888" FontSize="13" FontFamily="Segoe UI"
                   Margin="0,0,0,28"/>

        <!-- Divider -->
        <Rectangle Height="1" Fill="#FF2D2D2D" Margin="0,0,0,24"/>

        <!-- Author -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,12">
            <TextBlock Text="Developed by " Foreground="#FF888888"
                       FontSize="13" FontFamily="Segoe UI" VerticalAlignment="Center"/>
            <TextBlock Text="Shane" Foreground="#FFE0E0E0"
                       FontSize="13" FontWeight="SemiBold" FontFamily="Segoe UI"
                       VerticalAlignment="Center"/>
        </StackPanel>

        <!-- GitHub link -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,32">
            <TextBlock Text="GitHub: " Foreground="#FF888888"
                       FontSize="13" FontFamily="Segoe UI" VerticalAlignment="Center"/>
            <TextBlock VerticalAlignment="Center">
                <Hyperlink x:Name="GitHubLink" RequestNavigate="GitHubLink_RequestNavigate"
                           NavigateUri="https://github.com/dfwdino/MeetingNotes"
                           Foreground="#FF3A9EFF">
                    github.com/dfwdino/MeetingNotes
                </Hyperlink>
            </TextBlock>
        </StackPanel>

        <!-- Close button -->
        <Button Content="Close" Style="{DynamicResource PrimaryButton}"
                Width="100" HorizontalAlignment="Center"
                Click="CloseButton_Click"/>

    </StackPanel>
</Window>
