<Window x:Class="MeetingNotes.Views.EncryptPasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Encrypt Meeting"
        Width="380" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#FF1E1E1E"
        Foreground="#FFDCDCDC">

    <Window.Resources>
        <Style x:Key="DialogLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFAAAAAA"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style x:Key="DialogPasswordBox" TargetType="PasswordBox">
            <Setter Property="Background" Value="#FF2D2D2D"/>
            <Setter Property="Foreground" Value="#FFDCDCDC"/>
            <Setter Property="BorderBrush" Value="#FF3A3A3A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
    </Window.Resources>

    <StackPanel Margin="24,20,24,24">

        <TextBlock x:Name="TitleText" FontSize="16" FontWeight="SemiBold"
                   Foreground="#FFDCDCDC" Margin="0,0,0,4"/>

        <TextBlock x:Name="SubtitleText" FontSize="12" Foreground="#FF888888"
                   TextWrapping="Wrap" Margin="0,0,0,16"/>

        <TextBlock Text="Password" Style="{StaticResource DialogLabel}"/>
        <PasswordBox x:Name="PasswordBox" Style="{StaticResource DialogPasswordBox}"
                     Margin="0,0,0,12" PasswordChanged="PasswordBox_Changed"/>

        <StackPanel x:Name="ConfirmPanel" Visibility="Collapsed">
            <TextBlock Text="Confirm password" Style="{StaticResource DialogLabel}"/>
            <PasswordBox x:Name="ConfirmBox" Style="{StaticResource DialogPasswordBox}"
                         Margin="0,0,0,12" PasswordChanged="PasswordBox_Changed"/>
        </StackPanel>

        <TextBlock x:Name="ErrorText" Foreground="#FFFF6B6B" FontSize="12"
                   Visibility="Collapsed" Margin="0,0,0,8" TextWrapping="Wrap"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button x:Name="CancelButton" Content="Cancel" Width="80"
                    Background="#FF2D2D2D" Foreground="#FFDCDCDC"
                    BorderBrush="#FF3A3A3A" Padding="0,6"
                    Margin="0,0,8,0" Click="CancelButton_Click"/>
            <Button x:Name="OkButton" Content="OK" Width="80"
                    Background="#FF0078D4" Foreground="White"
                    BorderThickness="0" Padding="0,6"
                    IsDefault="True" Click="OkButton_Click"/>
        </StackPanel>

    </StackPanel>
</Window>
