<Window x:Class="MeetingNotes.Views.NewFolderDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="New Folder" Height="175" Width="380"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource PanelBackgroundBrush}">
    <StackPanel Margin="20">
        <TextBlock Text="Folder name" Foreground="#FF888888" FontSize="12" Margin="0,0,0,8"/>
        <TextBox x:Name="FolderNameBox" Style="{DynamicResource DarkTextBox}"
                 Margin="0,0,0,16"
                 KeyDown="FolderNameBox_KeyDown"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Style="{DynamicResource GhostButton}"
                    Margin="0,0,8,0" Click="CancelButton_Click"/>
            <Button Content="Create" Style="{DynamicResource PrimaryButton}"
                    Click="CreateButton_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
