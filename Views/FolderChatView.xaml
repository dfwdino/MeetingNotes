<Page x:Class="MeetingNotes.Views.FolderChatView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.modernwpf.com/2019"
      Background="{DynamicResource AppBackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource SeparatorBrush}" Padding="24,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock x:Name="FolderNameText" FontSize="20" FontWeight="SemiBold"
                               Foreground="{DynamicResource HeaderTextBrush}"/>
                    <TextBlock x:Name="SubtitleText" FontSize="12" Margin="0,3,0,0"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                </StackPanel>
                <Button x:Name="ClearChatButton" Grid.Column="1"
                        Content="Clear chat" Style="{DynamicResource GhostButton}"
                        VerticalAlignment="Center" Click="ClearChat_Click"/>
            </Grid>
        </Border>

        <!-- Chat area -->
        <Grid Grid.Row="1">
            <!-- Hint shown before first message -->
            <StackPanel x:Name="ChatHint" VerticalAlignment="Center" HorizontalAlignment="Center"
                        Margin="32,0">
                <TextBlock Text="💬" FontSize="40" HorizontalAlignment="Center" Margin="0,0,0,14"/>
                <TextBlock x:Name="HintText" FontSize="14" HorizontalAlignment="Center"
                           TextAlignment="Center" TextWrapping="Wrap" MaxWidth="320"
                           Foreground="{DynamicResource TextMutedBrush}"/>
            </StackPanel>

            <!-- Messages -->
            <ScrollViewer x:Name="ChatScrollViewer" VerticalScrollBarVisibility="Auto"
                          Padding="24,16,24,8" Visibility="Collapsed">
                <StackPanel x:Name="ChatMessages"/>
            </ScrollViewer>
        </Grid>

        <!-- Input bar -->
        <Border Grid.Row="2" BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource SeparatorBrush}" Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="ChatInputBox"
                         Style="{DynamicResource DarkTextBox}"
                         ui:ControlHelper.PlaceholderText="Ask about all meetings in this folder…"
                         KeyDown="ChatInputBox_KeyDown"/>
                <Button Grid.Column="1" Content="Send"
                        Style="{DynamicResource PrimaryButton}"
                        Margin="8,0,0,0" Click="SendButton_Click"/>
            </Grid>
        </Border>
    </Grid>
</Page>
