<Window x:Class="MeetingNotes.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        xmlns:views="clr-namespace:MeetingNotes.Views"
        xmlns:vm="clr-namespace:MeetingNotes.ViewModels"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="Meeting Notes" Height="760" Width="1280" Icon="/MeetingNotes.ico"
        MinHeight="600" MinWidth="900"
        Background="{DynamicResource AppBackgroundBrush}"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="1" />
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="1"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left Border Lines -->
        <Rectangle Grid.Column="1" Fill="{DynamicResource SeparatorBrush}"/>
        <Rectangle Grid.Column="3" Fill="{DynamicResource SeparatorBrush}"/>

        <!-- ══════════════════════════════════════ -->
        <!-- SIDEBAR                                -->
        <!-- ══════════════════════════════════════ -->
        <Grid Grid.Column="0" Background="{DynamicResource SidebarBackgroundBrush}">
            <!-- Full sidebar — visible when expanded -->
            <Grid x:Name="SidebarContent">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="16,16,16,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="FOLDERS" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"
                           FontWeight="SemiBold" VerticalAlignment="Center"/>
                <Button x:Name="CollapseSidebarButton" Grid.Column="1"
                        Content="◀" ToolTip="Hide folders"
                        Style="{DynamicResource GhostButton}"
                        Padding="6,3" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"
                        Click="CollapseSidebarButton_Click"/>
            </Grid>

            <!-- New Folder Button -->
            <Button Grid.Row="1" Content="＋  New Folder"
                    Style="{DynamicResource PrimaryButton}"
                    Margin="10,0,10,12"
                    Click="NewFolderButton_Click"/>

            <!-- Folder List -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- All Meetings -->
                    <Border x:Name="AllMeetingsBorder" Cursor="Hand"
                            MouseLeftButtonDown="AllMeetings_Click">
                        <Grid Margin="16,9">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="📁" FontSize="15" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="All Meetings"
                                       Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13.5"
                                       Margin="10,0,0,0" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Trash -->
                    <Border x:Name="TrashBorder" Cursor="Hand"
                            MouseLeftButtonDown="Trash_Click">
                        <Grid Margin="16,9">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="🗑" FontSize="15" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="Trash"
                                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13.5"
                                       Margin="10,0,0,0" VerticalAlignment="Center"/>
                            <!-- Trash count badge -->
                            <Border x:Name="TrashCountBadge" Grid.Column="2"
                                    CornerRadius="10" Padding="6,1"
                                    Background="#FF3A1A1A" Visibility="Collapsed">
                                <TextBlock x:Name="TrashCountText" FontSize="11"
                                           Foreground="#FFEF5350"/>
                            </Border>
                        </Grid>
                    </Border>

                    <Rectangle Height="1" Fill="{DynamicResource SeparatorBrush}" Margin="0,4"/>

                    <!-- Dynamic Folders -->
                    <ItemsControl x:Name="FolderList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:FolderViewModel}">
                                <Border x:Name="FolderCardBorder"
                                        Cursor="Hand"
                                        MouseLeftButtonDown="FolderItem_Click"
                                        Tag="{Binding}">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource FolderSelectedBrush}"/>
                                                </DataTrigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource CardHoverBrush}"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid Margin="16,9">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Active indicator -->
                                        <Border Width="3" HorizontalAlignment="Left"
                                                Margin="-16,0,0,0" CornerRadius="0,2,2,0">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                            <Setter Property="Background" Value="#FF0078D4"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                        </Border>

                                        <TextBlock Text="📁" FontSize="15" VerticalAlignment="Center"/>

                                        <!-- Folder name — read mode -->
                                        <TextBlock Grid.Column="1" Text="{Binding Name}"
                                                   FontSize="13.5" Margin="10,0,0,0"
                                                   VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#FFCCCCCC"/>
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                            <Setter Property="Foreground" Value="White"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <!-- Folder name — edit mode (inline rename) -->
                                        <TextBox Grid.Column="1"
                                                 Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 FontSize="13.5" FontFamily="Segoe UI"
                                                 Foreground="{DynamicResource TextPrimaryBrush}" Background="{DynamicResource InputBackgroundBrush}"
                                                 BorderBrush="#FF0078D4" BorderThickness="1"
                                                 Padding="3,1" Margin="8,0,4,0"
                                                 VerticalAlignment="Center"
                                                 Tag="{Binding}"
                                                 KeyDown="FolderNameBox_KeyDown"
                                                 LostFocus="FolderNameBox_LostFocus"
                                                 IsVisibleChanged="FolderNameBox_VisibleChanged">
                                            <TextBox.Style>
                                                <Style TargetType="TextBox">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBox.Style>
                                        </TextBox>

                                        <!-- Meeting count badge -->
                                        <Border Grid.Column="2" CornerRadius="10" Padding="6,1">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="{DynamicResource BadgeBackgroundBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource BadgeSelectedBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding MeetingCount}" FontSize="11">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#FFAAAAAA"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                <Setter Property="Foreground" Value="#FF7AB3E0"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>

                                        <!-- Rename button — appears on hover -->
                                        <Button Grid.Column="3" Content="✏" FontSize="12"
                                                VerticalAlignment="Center" Padding="5,2"
                                                Cursor="Hand" Foreground="#FFAAAAAA"
                                                Tag="{Binding}" Click="RenameFolder_Click">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Visibility" Value="Hidden"/>
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Setter Property="BorderThickness" Value="0"/>
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border Background="Transparent" Padding="{TemplateBinding Padding}">
                                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsMouseOver, ElementName=FolderCardBorder}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>

                                        <!-- Delete button — appears on hover -->
                                        <Button Grid.Column="4" Content="×" FontSize="16"
                                                VerticalAlignment="Center" Padding="6,2"
                                                Cursor="Hand" Foreground="#FFAAAAAA"
                                                Tag="{Binding}" Click="DeleteFolder_Click">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Visibility" Value="Hidden"/>
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Setter Property="BorderThickness" Value="0"/>
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border Background="Transparent" Padding="{TemplateBinding Padding}">
                                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsMouseOver, ElementName=FolderCardBorder}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>

            <!-- Footer -->
            <Border Grid.Row="3" BorderThickness="0,1,0,0" BorderBrush="{DynamicResource SeparatorBrush}" Padding="16,12">
                <Grid>
                    <Button Content="⚙  Settings" Style="{DynamicResource GhostButton}"
                            HorizontalAlignment="Left" Click="SettingsButton_Click"/>
                    <Button Content="ℹ" Style="{DynamicResource GhostButton}"
                            HorizontalAlignment="Right" Width="32" Padding="0"
                            FontSize="15" ToolTip="About"
                            Click="AboutButton_Click"/>
                </Grid>
            </Border>
            </Grid><!-- /SidebarContent -->

            <!-- Collapsed strip — 32 px wide, shown instead of full sidebar -->
            <Border x:Name="SidebarCollapsedStrip" Visibility="Collapsed" Background="{DynamicResource SidebarBackgroundBrush}">
                <Button VerticalAlignment="Top" HorizontalAlignment="Stretch"
                        Height="36" Margin="2,8,2,0"
                        ToolTip="Show Folders"
                        Click="ExpandSidebarButton_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bg" Background="#FF2D3A4A" CornerRadius="4"
                                    BorderBrush="#FF3A5A7A" BorderThickness="1">
                                <TextBlock Text="▶" Foreground="#FF5B9BD5" FontSize="11"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bg" Property="Background" Value="#FF3A4D60"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Border>
        </Grid>

        <!-- ══════════════════════════════════════ -->
        <!-- MEETING LIST                           -->
        <!-- ══════════════════════════════════════ -->
        <Grid x:Name="MeetingListPanel" Grid.Column="2" Background="{DynamicResource PanelBackgroundBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="16,16,16,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <!-- Collapse panel button — left side so it can't be confused with + New -->
                <Button x:Name="CollapseListButton" Grid.Column="0"
                        Content="◀" ToolTip="Hide meeting list"
                        Style="{DynamicResource GhostButton}"
                        Padding="6,5" FontSize="13" Margin="0,0,4,0" Foreground="{DynamicResource TextSecondaryBrush}"
                        Click="CollapseListButton_Click"/>
                <TextBlock x:Name="FolderTitleText" Grid.Column="1" Text="All Meetings"
                           Foreground="{DynamicResource HeaderTextBrush}" FontSize="16" FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
                <!-- Search toggle button -->
                <Button x:Name="SearchToggleButton" Grid.Column="2"
                        Content="🔍" ToolTip="Search meetings"
                        Style="{DynamicResource GhostButton}"
                        Padding="6,5" FontSize="13" Margin="0,0,2,0"
                        Click="SearchToggle_Click"/>
                <Button x:Name="NewMeetingButton" Grid.Column="3" Content="＋  New"
                        Style="{DynamicResource PrimaryButton}"
                        Padding="10,5" FontSize="12" Margin="4,0,0,0"
                        Visibility="Collapsed"
                        Click="NewMeetingButton_Click"/>
            </Grid>

            <!-- Search — hidden by default, toggled by 🔍 button -->
            <Border x:Name="SearchRow" Grid.Row="1" Margin="12,0,12,10"
                    Visibility="Collapsed">
                <TextBox x:Name="SearchBox" Style="{DynamicResource DarkTextBox}"
                         ui:ControlHelper.PlaceholderText="Search meetings..."
                         TextChanged="SearchBox_TextChanged"/>
            </Border>

            <!-- Meeting Items -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="MeetingList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:MeetingViewModel}">
                            <Border x:Name="MeetingCardBorder"
                                    BorderThickness="0,0,0,1" BorderBrush="{DynamicResource SeparatorBrush}"
                                    Cursor="Hand" Padding="16,12"
                                    MouseLeftButtonDown="MeetingItem_Click"
                                    Tag="{Binding}">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource CardSelectedBrush}"/>
                                            </DataTrigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource CardHoverBrush}"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding Title}" FontSize="13.5"
                                               FontWeight="Medium" Foreground="{DynamicResource TextPrimaryBrush}"
                                               Margin="0,0,0,4" TextTrimming="CharacterEllipsis"/>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock FontSize="11.5" Foreground="#FF666666">
                                            <Run Text="{Binding DateDisplay, Mode=OneWay}"/>
                                            <Run Text=" · "/>
                                            <Run Text="{Binding DurationDisplay, Mode=OneWay}"/>
                                        </TextBlock>
                                        <!-- Status Badge -->
                                        <Border Margin="8,0,0,0" CornerRadius="10" Padding="7,2">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Ready">
                                                            <Setter Property="Background" Value="#FF1A3D1A"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Processing">
                                                            <Setter Property="Background" Value="#FF3D2E00"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Recording">
                                                            <Setter Property="Background" Value="#FF3D1A1A"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="New">
                                                            <Setter Property="Background" Value="{DynamicResource CardHoverBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding StatusDisplay}" FontSize="10" FontWeight="Medium">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="Ready">
                                                                <Setter Property="Foreground" Value="#FF4CAF50"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="Processing">
                                                                <Setter Property="Foreground" Value="#FFFFA726"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="Recording">
                                                                <Setter Property="Foreground" Value="#FFEF5350"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="New">
                                                                <Setter Property="Foreground" Value="#FF888888"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                                    <!-- Normal: Move + Delete buttons (appear on hover) -->
                                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                                VerticalAlignment="Center">
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Setter Property="Visibility" Value="Hidden"/>
                                                <Style.Triggers>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding IsMouseOver, ElementName=MeetingCardBorder}" Value="True"/>
                                                            <Condition Binding="{Binding IsDeleted}" Value="False"/>
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>
                                        <!-- Move to folder -->
                                        <Button Content="📁" FontSize="13" ToolTip="Move to folder..."
                                                Padding="6,3" Cursor="Hand" Foreground="#FFAAAAAA"
                                                Tag="{Binding}" Click="MoveMeeting_Click"
                                                Background="Transparent" BorderThickness="0">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="Transparent" Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                        <!-- Delete -->
                                        <Button Content="×" FontSize="16"
                                                Padding="6,3" Cursor="Hand" Foreground="#FFAAAAAA"
                                                Tag="{Binding}" Click="DeleteMeeting_Click"
                                                Background="Transparent" BorderThickness="0">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="Transparent" Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </StackPanel>

                                    <!-- Trash: Restore + Delete Forever buttons -->
                                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                                VerticalAlignment="Center">
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsDeleted}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>
                                        <Button Content="↩" FontSize="15" ToolTip="Restore (text only)"
                                                Padding="6,3" Cursor="Hand" Foreground="#FF4CAF50"
                                                Tag="{Binding}" Click="RestoreMeeting_Click"
                                                Background="Transparent" BorderThickness="0">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="Transparent" Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                        <Button Content="✕" FontSize="13" ToolTip="Remove from Trash (data kept in DB)"
                                                Padding="6,3" Cursor="Hand" Foreground="#FFEF5350"
                                                Tag="{Binding}" Click="HideFromTrash_Click"
                                                Background="Transparent" BorderThickness="0">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="Transparent" Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <!-- ══════════════════════════════════════ -->
        <!-- DETAIL / CONTENT AREA                  -->
        <!-- ══════════════════════════════════════ -->
        <Grid Grid.Column="4" Background="{DynamicResource AppBackgroundBrush}">
            <!-- Content Frame - swapped by code-behind -->
            <Frame x:Name="ContentFrame" NavigationUIVisibility="Hidden"
                   Background="Transparent"/>

            <!-- Empty state -->
            <StackPanel x:Name="EmptyState" VerticalAlignment="Center"
                        HorizontalAlignment="Center">
                <TextBlock Text="🎙️" FontSize="48" HorizontalAlignment="Center"
                           Margin="0,0,0,16"/>
                <TextBlock Text="Select a meeting or create a new one"
                           Foreground="{DynamicResource TextMutedBrush}" FontSize="14"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- Shows in content column when meeting list is collapsed -->
        <Button x:Name="ExpandListButton"
                Grid.Column="4"
                ToolTip="Show Meetings"
                Visibility="Collapsed"
                VerticalAlignment="Top"
                HorizontalAlignment="Left"
                Height="36"
                Width="130"
                Margin="12,8,0,0"
                Panel.ZIndex="10"
                Click="ExpandListButton_Click">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bg" Background="#FF2D3A4A" CornerRadius="6"
                            BorderBrush="#FF3A5A7A" BorderThickness="1">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <TextBlock Text="▶" Foreground="#FF5B9BD5" FontSize="12"
                                       VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Meetings" Foreground="{DynamicResource TextPrimaryBrush}"
                                       FontSize="12" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bg" Property="Background" Value="#FF3A4D60"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>

    </Grid>
</Window>
