<Page x:Class="MeetingNotes.Views.RecordingView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.modernwpf.com/2019"
      Background="{DynamicResource AppBackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Header -->
            <RowDefinition Height="Auto"/>  <!-- Controls (timer / waveform / stop) -->
            <RowDefinition Height="*"/>     <!-- Quick Notes fills remaining space -->
        </Grid.RowDefinitions>

        <!-- Header — compact -->
        <Border Grid.Row="0" BorderThickness="0,0,0,1" BorderBrush="#FF2D2D2D" Padding="16,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border CornerRadius="14" Padding="10,4" Background="#FF3D1A1A">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse x:Name="RecDot" Width="7" Height="7" Fill="#FFEF5350"
                                 VerticalAlignment="Center" Margin="0,0,5,0" Opacity="0"/>
                        <TextBlock Text="REC" Foreground="#FFEF5350" FontSize="11" FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>
                <TextBlock Grid.Column="1" x:Name="MeetingTitleText"
                           Foreground="{DynamicResource HeaderTextBrush}" FontSize="15" FontWeight="SemiBold"
                           VerticalAlignment="Center" Margin="12,0"/>
                <Border Grid.Column="2" Background="{DynamicResource PanelBackgroundBrush}" CornerRadius="4" Padding="8,3">
                    <TextBlock x:Name="FolderBadgeText" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                </Border>
            </Grid>
        </Border>

        <!-- Pre-recording device picker — shown before recording starts -->
        <StackPanel x:Name="PreRecordPanel" Grid.Row="1" HorizontalAlignment="Center"
                    Margin="0,18,0,10">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="System Audio"
                           Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox x:Name="PreLoopbackDeviceBox" Grid.Column="1"
                          Background="{DynamicResource InputBackgroundBrush}"
                          Foreground="{DynamicResource TextPrimaryBrush}"
                          BorderBrush="#FF3A3A3A" FontSize="13"/>

                <TextBlock Grid.Column="3" Text="Microphone"
                           Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox x:Name="PreMicDeviceBox" Grid.Column="4"
                          Background="{DynamicResource InputBackgroundBrush}"
                          Foreground="{DynamicResource TextPrimaryBrush}"
                          BorderBrush="#FF3A3A3A" FontSize="13"/>

                <Button x:Name="StartButton" Grid.Column="6"
                        Width="140" Height="34" Click="StartButton_Click"
                        Style="{DynamicResource PrimaryButton}">
                    Start Recording
                </Button>
            </Grid>

        </StackPanel>

        <!-- Controls — shown once recording is active -->
        <Grid x:Name="RecordingPanel" Grid.Row="1" Margin="16,12,16,10" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- Timer / waveform / stop row -->
                <RowDefinition Height="Auto"/>  <!-- Audio source badges -->
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>  <!-- Timer (left) -->
                <ColumnDefinition Width="*"/>     <!-- Waveform (center) -->
                <ColumnDefinition Width="Auto"/>  <!-- Stop button (right) -->
            </Grid.ColumnDefinitions>

            <!-- Timer (left) -->
            <StackPanel Grid.Column="0" Grid.Row="0" VerticalAlignment="Center" Margin="0,0,20,0">
                <TextBlock x:Name="TimerText" Text="00:00:00"
                           Foreground="{DynamicResource TextPrimaryBrush}" FontSize="34" FontWeight="Light"/>
                <TextBlock Text="Recording in progress" Foreground="{DynamicResource TextSecondaryBrush}"
                           FontSize="11" Margin="0,2,0,0"/>
            </StackPanel>

            <!-- Waveform (center) -->
            <ItemsControl x:Name="WaveformDisplay" Grid.Column="1" Grid.Row="0"
                          Height="60" ClipToBounds="True" VerticalAlignment="Center" HorizontalAlignment="Center">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Rectangle Width="5" Height="{Binding}" Margin="2,0"
                                   Fill="#FF1E90FF" RadiusX="2" RadiusY="2"
                                   VerticalAlignment="Center"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Stop button (right) -->
            <StackPanel Grid.Column="2" Grid.Row="0" VerticalAlignment="Center" Margin="20,0,0,0">
                <Button x:Name="StopButton" Width="50" Height="50"
                        HorizontalAlignment="Center" Click="StopButton_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="StopBorder" Width="50" Height="50"
                                    CornerRadius="25" Background="#FFC42B1C">
                                <Border.Effect>
                                    <DropShadowEffect Color="#FFC42B1C" BlurRadius="14"
                                                      ShadowDepth="0" Opacity="0.45"/>
                                </Border.Effect>
                                <Rectangle Width="18" Height="18" Fill="White" RadiusX="2" RadiusY="2"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="StopBorder" Property="Background" Value="#FFE03B2A"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <TextBlock Text="Click to stop recording" Foreground="{DynamicResource TextSecondaryBrush}"
                           FontSize="11" HorizontalAlignment="Center" Margin="0,8,0,0"/>
            </StackPanel>

            <!-- Audio source badges — click to mute/unmute for this session -->
            <StackPanel Grid.Row="1" Grid.ColumnSpan="3"
                        Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                <Border x:Name="LoopbackBorder" Background="#FF151F15" BorderBrush="#FF1A3D1A"
                        BorderThickness="1" CornerRadius="6" Padding="12,5" Margin="0,0,8,0"
                        Cursor="Hand" ToolTip="Click to mute/unmute system audio"
                        MouseLeftButtonUp="LoopbackBorder_Click">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse x:Name="LoopbackDot" Width="6" Height="6" Fill="#FF4CAF50"
                                 VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock x:Name="LoopbackLabel" Text="System Audio"
                                   Foreground="#FF4CAF50" FontSize="11"/>
                    </StackPanel>
                </Border>
                <Border x:Name="MicBorder" Background="#FF151F15" BorderBrush="#FF1A3D1A"
                        BorderThickness="1" CornerRadius="6" Padding="12,5"
                        Cursor="Hand" ToolTip="Click to mute/unmute microphone"
                        MouseLeftButtonUp="MicBorder_Click">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse x:Name="MicDot" Width="6" Height="6" Fill="#FF4CAF50"
                                 VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock x:Name="MicLabel" Text="Microphone"
                                   Foreground="#FF4CAF50" FontSize="11"/>
                    </StackPanel>
                </Border>
            </StackPanel>

        </Grid>

        <!-- Quick Notes — fills all remaining space -->
        <Border Grid.Row="2" BorderThickness="0,1,0,0" BorderBrush="#FF2D2D2D" Padding="20,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="QUICK NOTES" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"
                           FontWeight="SemiBold" Margin="0,0,0,6"/>
                <TextBox Grid.Row="1" x:Name="QuickNotesBox"
                         Style="{DynamicResource DarkTextBox}"
                         AcceptsReturn="True" TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         ui:ControlHelper.PlaceholderText="Jot down anything while you record — saved with the meeting..."/>
            </Grid>
        </Border>

    </Grid>
</Page>
